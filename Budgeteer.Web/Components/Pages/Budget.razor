@page "/budget"
@rendermode InteractiveServer
@using Budgeteer.Budget.ReadModels
@using Budgeteer.Budget.Categorization
@using Budgeteer.Budget.Budgeting
@using Budgeteer.Web.Services
@inject BudgetService BudgetService
@inject BudgetAllocationService Allocations
@inject TransferDetectionService Transfers
@inject TransactionCategorizer Categorizer

<PageTitle>Budget</PageTitle>

<h1>Budget</h1>
<p class="text-muted">Spending by category. Change a category to teach Budgeteer — it will remember the payee next time.</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label mb-0">From</label>
                <input type="date" class="form-control form-control-sm" @bind="from" @bind:after="Apply" />
            </div>
            <div class="col-auto">
                <label class="form-label mb-0">To</label>
                <input type="date" class="form-control form-control-sm" @bind="to" @bind:after="Apply" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearPeriod">All time</button>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="DetectTransfers" disabled="@detecting">
                    @(detecting ? "Detecting…" : "Detect transfers")
                </button>
            </div>
            @if (transferMessage is not null)
            {
                <div class="col-auto"><span class="text-muted small">@transferMessage</span></div>
            }
            <div class="col text-end text-muted">
                @(from is { } f ? f.ToShortDateString() : "beginning") – @(to is { } t ? t.ToShortDateString() : "now")
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="alert alert-secondary">Loading…</div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <h6 class="card-title text-muted">Income</h6>
                <h3 class="text-success">€@incomeTotal.ToString("N2")</h3>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <h6 class="card-title text-muted">Expenses</h6>
                <h3 class="text-danger">€@expenseTotal.ToString("N2")</h3>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <h6 class="card-title text-muted">Net</h6>
                <h3 class="@((incomeTotal - expenseTotal) >= 0 ? "text-success" : "text-danger")">
                    €@((incomeTotal - expenseTotal).ToString("N2"))
                </h3>
            </div></div>
        </div>
    </div>

    <h4>Budget vs actual</h4>
    @if (budgetRows.Count == 0)
    {
        <div class="alert alert-info">No expenses yet. Import a bank export to get started.</div>
    }
    else
    {
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th style="width:18%">Category</th>
                    <th>Progress</th>
                    <th class="text-end">Spent</th>
                    <th class="text-end">Limit (monthly)</th>
                    <th class="text-end">Remaining</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in budgetRows)
                {
                    <tr>
                        <td>@r.Category</td>
                        <td>
                            @if (r.HasLimit)
                            {
                                <div class="progress" role="progressbar" style="height:20px">
                                    <div class="progress-bar @BarClass(r)" style="width:@Math.Min(100, r.Percent).ToString("F0")%">
                                        @r.Percent.ToString("F0")%
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">no limit set</span>
                            }
                        </td>
                        <td class="text-end">€@r.Spent.ToString("N2")</td>
                        <td class="text-end" style="width:140px">
                            @* Rendered invariantly: on an nl-NL server host, CurrentCulture would
                               emit "50,5", which browsers reject for number inputs (blank field). *@
                            <input type="number" min="0" step="10" class="form-control form-control-sm text-end"
                                   value="@(r.HasLimit ? r.MonthlyLimit.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                   @onchange="@(args => SetLimit(r.Category, args.Value?.ToString()))" />
                        </td>
                        <td class="text-end @(r.OverBudget ? "text-danger fw-bold" : "")">
                            @(r.HasLimit ? $"€{r.Remaining:N2}" : "—")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <small class="text-muted">
            You set a <strong>monthly</strong> limit; it's scaled to the <strong>@periodMonths month(s)</strong>
            in the selected period to compare against actual spend. Set a limit to 0 to clear it.
        </small>
    }

    <h4 class="mt-4">Expenses</h4>
    @if (expenses.Count > 0)
    {
        <table class="table table-striped table-sm">
            <thead>
                <tr><th>Date</th><th>Payee</th><th>Description</th><th class="text-end">Amount</th><th>Category</th></tr>
            </thead>
            <tbody>
                @foreach (var e in expenses.OrderByDescending(x => x.Date))
                {
                    <tr>
                        <td>@e.Date.ToShortDateString()</td>
                        <td>@e.Payee</td>
                        <td>@e.Description</td>
                        <td class="text-end text-danger">€@e.Amount.ToString("N2")</td>
                        <td>
                            <select class="form-select form-select-sm"
                                    value="@(e.Category ?? "")"
                                    @onchange="@(args => Recategorize(e.Id, args.Value?.ToString()))">
                                <option value="">Uncategorized</option>
                                @foreach (var c in categories)
                                {
                                    <option value="@c" selected="@(string.Equals(c, e.Category, StringComparison.OrdinalIgnoreCase))">@c</option>
                                }
                            </select>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private bool loading = true;

    // Full data, loaded once.
    private List<ExpenseView> allExpenses = new();
    private List<Budgeteer.Budget.Domain.Income> allIncome = new();

    // Date-range filter.
    private DateTime? from;
    private DateTime? to;

    // Transfers between own accounts (excluded from income/expense/spending).
    private HashSet<string> transferIds = new();
    private bool detecting;
    private string? transferMessage;

    // Derived (filtered) view state.
    private List<ExpenseView> expenses = new();
    private decimal incomeTotal;
    private decimal expenseTotal;
    private IReadOnlyList<(string Category, decimal Total, int Count)> spending = new List<(string, decimal, int)>();
    private IReadOnlyList<CategoryBudget> budgetRows = new List<CategoryBudget>();
    private List<BudgetAllocation> allocations = new();
    private List<string> categories = new();
    private int periodMonths = 1;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        allExpenses = await BudgetService.LoadExpensesAsync();
        allIncome = await BudgetService.LoadIncomeAsync();
        allocations = await Allocations.GetAllAsync();
        transferIds = await Transfers.GetTransferTransactionIdsAsync();

        // Category options are stable (independent of the date filter).
        var rules = await Categorizer.GetRulesAsync();
        categories = rules.Select(r => r.Category)
            .Concat(allExpenses.Select(e => e.Category ?? ""))
            .Concat(allIncome.Select(i => i.Category ?? ""))
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList();

        Apply();
        loading = false;
    }

    private void Apply()
    {
        // Exclude transfers between own accounts from spending/income.
        expenses = allExpenses.Where(e => InRange(e) && !transferIds.Contains(e.TransactionId)).ToList();
        incomeTotal = allIncome.Where(i => InRange(i.Date) && !transferIds.Contains(i.TransactionId)).Sum(i => i.Amount);
        expenseTotal = expenses.Sum(e => e.Amount);
        spending = BudgetService.SpendingByCategory(expenses);
        periodMonths = ComputePeriodMonths();
        budgetRows = BudgetAllocationService.BuildBudgetRows(spending, allocations, periodMonths);
    }

    // Number of months in the inspected window, so monthly limits can be scaled to it.
    private int ComputePeriodMonths()
    {
        DateTime? lo = from, hi = to;
        if ((lo is null || hi is null) && expenses.Count > 0)
        {
            lo ??= expenses.Min(e => e.Date);
            hi ??= expenses.Max(e => e.Date);
        }
        if (lo is { } l && hi is { } h)
            return Math.Max(1, (h.Year - l.Year) * 12 + (h.Month - l.Month) + 1);
        return 1;
    }

    private async Task DetectTransfers()
    {
        detecting = true;
        try
        {
            var found = await Transfers.DetectAsync();
            transferMessage = found > 0 ? $"Found {found} new transfer(s)." : "No new transfers found.";
            await Load();
        }
        catch (Exception ex)
        {
            transferMessage = $"Detection failed: {ex.Message}";
        }
        finally
        {
            detecting = false;
        }
    }

    private async Task SetLimit(string category, string? raw)
    {
        // Blank intentionally clears the limit; an unparseable value is ignored so a typo
        // can't silently wipe a configured budget.
        if (!string.IsNullOrWhiteSpace(raw) &&
            !decimal.TryParse(raw, System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out _))
        {
            return;
        }
        decimal.TryParse(raw, System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture, out var limit);
        try
        {
            await Allocations.SetAsync(category, limit);
            allocations = await Allocations.GetAllAsync();
            Apply();
        }
        catch (Exception ex)
        {
            transferMessage = $"Could not save the limit: {ex.Message}";
        }
    }

    private static string BarClass(CategoryBudget r) =>
        r.OverBudget ? "bg-danger" : r.NearLimit ? "bg-warning" : "bg-success";

    private bool InRange(ExpenseView e) => InRange(e.Date);
    private bool InRange(DateTime d) =>
        (from is not { } f || d.Date >= f.Date) && (to is not { } t || d.Date <= t.Date);

    private void ClearPeriod()
    {
        from = null;
        to = null;
        Apply();
    }

    private async Task Recategorize(string expenseId, string? category)
    {
        try
        {
            await BudgetService.RecategorizeAsync(expenseId, category ?? "");
            await Load();
        }
        catch (Exception ex)
        {
            transferMessage = $"Could not recategorize: {ex.Message}";
        }
    }
}
